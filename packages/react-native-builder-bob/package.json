    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "arktype": "^2.2.0",
    "babel-plugin-syntax-hermes-parser": "^0.34.0",
    "browserslist": "^4.28.2",
    "cross-spawn": "^7.0.6",
    "dedent": "^1.7.2",
    "del": "^8.0.1",
    "escape-string-regexp": "^5.0.0",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "is-git-dirty": "^2.0.2",
    "json5": "^2.2.3",
    "kleur": "^4.1.5",
    "prompts": "^2.4.2",
